generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id           String   @id @default(uuid())
  passport_no  String   @unique
  name         String
  phone        String?
  whatsapp     String?

  // 持有人身份信息
  place_of_birth    String?
  passport_expiry   DateTime?
  nationality       String?
  gender            String?

  // 居留细节信息
  address           String?
  activity          String?
  occupation        String?
  guarantor         String?

  // 签发机构信息
  ministry_name     String?
  issuing_office    String?
  issuing_date      DateTime?
  issuing_location  String?
  office_address    String?

  visaRecords  VisaRecord[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([passport_no])
  @@map("customers")
}

model VisaRecord {
  id               String   @id @default(uuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  visaTypeCode     String
  visaType         VisaType @relation(fields: [visaTypeCode], references: [code])

  passport_no      String
  expiry_date      DateTime
  is_urgent        Boolean  @default(false)
  reminder_enabled Boolean  @default(false)
  entry_date       DateTime?
  port_of_entry    String?
  file_url         String?

  reminders        Reminder[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([customerId, visaTypeCode, expiry_date])
  @@index([customerId])
  @@index([visaTypeCode])
  @@index([expiry_date])
}

model SystemLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  level     String
  module    String
  message   String
  user      String?
  metadata  Json?

  @@index([timestamp, level])
  @@index([module])
  @@map("system_logs")
}

model Reminder {
  id                String      @id @default(uuid())
  visa_id           String
  visa              VisaRecord  @relation(fields: [visa_id], references: [id], onDelete: Cascade)

  customer_name     String
  passport_no       String
  visa_type         String
  expiry_date       DateTime

  days_left         Int
  stage             String
  status            String

  last_sent_at      DateTime?
  retry_count       Int         @default(0)
  is_acknowledged   Boolean     @default(false)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([visa_id])
  @@index([days_left, status])
  @@map("reminders")
}

model AppSettings {
  id                      String   @id @default("singleton")

  email_account           String   @default("admin@bantuqifu.com")
  email_password          String?
  email_filter            String   @default("@imigrasi.go.id")
  email_frequency_minutes Int      @default(5)

  wecom_webhook_url       String?
  voice_bot_api_key       String?
  voice_call_time         String   @default("working-hours")
  voice_receiver          String   @default("wangshuo")

  updatedAt               DateTime @updatedAt

  @@map("app_settings")
}

model VisaType {
  id            String   @id @default(uuid())
  code          String   @unique
  nameZh        String
  nameId        String
  requiresEntry Boolean  @default(false)
  isActive      Boolean  @default(true)
  visaRecords   VisaRecord[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("visa_types")
}

model EmailProcessLog {
  id              String   @id @default(uuid())
  messageId       String
  pdfKey          String
  pdfFilename     String

  status          String   @default("PENDING")
  extractedData   Json?
  errorMessage    String?

  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([messageId])
  @@index([status])
  @@index([createdAt])
  @@map("email_process_logs")
}
